# ============================================================
# Poke Hanoi — Environment variables
# Copy file này thành `.env.local` rồi điền giá trị thật.
# KHÔNG commit `.env.local` (đã có trong .gitignore).
# ============================================================

# --- Supabase (Phase 02 / 04 / 05) ---
# Lấy ở: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# [BẮT BUỘC sau scale-up P0] service role key — server insert đơn + đọc lại order_token,
# bỏ qua RLS đã siết. Lấy ở Project Settings → API → service_role. CHỈ dùng server-side.
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (Phase 06) — gpt-4o-mini. CHỈ dùng server-side ---
# Lấy ở: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Admin dashboard ---
# [ĐÃ BỎ sau scale-up P0] /admin giờ dùng Supabase Auth (tài khoản nhân viên),
# không còn dùng ADMIN_PASSWORD. Tạo staff user trong Supabase → Authentication.

# --- VietQR + SePay (thanh toán QR tự xác nhận) ---
# Mã ngân hàng theo chuẩn VietQR/SePay, vd: VCB, MB, TCB, ACB... (xem qr.sepay.vn/banks.json)
NEXT_PUBLIC_VIETQR_BANK=
# Số tài khoản nhận tiền của quán (tài khoản SePay đang theo dõi)
NEXT_PUBLIC_VIETQR_ACCOUNT=
# Tên chủ tài khoản (in trên QR)
NEXT_PUBLIC_VIETQR_NAME=
# [BẮT BUỘC để auto-confirm] API key webhook SePay — server-only.
# SePay dashboard → WebHooks → tạo webhook trỏ về https://<domain>/api/webhooks/sepay,
# Authentication = Api_Key, rồi dán đúng key đó vào đây.
SEPAY_WEBHOOK_API_KEY=

# --- Cấu hình quán (Phase 07) ---
# Số bàn tối đa để sinh QR per-bàn (?table=1..N)
NEXT_PUBLIC_TABLE_COUNT=10
